#!/usr/bin/env bash

ollup_prompt="OLLUP:"

update_models() {
    local -a models failed_updates 
    readarray -t models < <(ollama ls | awk 'NR >= 2 && NF {print $1}')

    echo "$ollup_prompt Updating Ollama models..."
    for model in "${models[@]}"; do
        echo "$ollup_prompt Updating model $model..."
        ollama pull "$model" || failed_updates+=("$model")
    done

    echo "$ollup_prompt Finished updating models."
    if (( ${#failed_updates[@]} > 0 )); then
        echo "$ollup_prompt The following models failed to update:" >&2
        for failure in "${failed_updates[@]}"; do
            printf "%s %s\n" "$ollup_prompt" "$failure" >&2
        done
    fi
    return 0
}

# If there is no server, then ollama list returns 1.
if ! ollama list > /dev/null 2>&1; then
    echo "$ollup_prompt Ollama is not running; no models were updated." >&2
    exit 1
fi

update_models
